{
  "grammars": [
    {
      "name": "hv",
      "camelcase": "Hv",
      "scope": "source.hv",
      "path": ".",
      "file-types": [
        "hv"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Hash Visualiser (.hv) DSL",
    "links": {
      "repository": "https://github.com/ChrisWhealy/hash_visualiser"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
